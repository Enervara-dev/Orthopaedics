# Copy to .env and fill in. .env is gitignored — never commit real keys.
# Variable names must match graphrag/config/settings.py (case-sensitive).

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED (the pipeline fails fast at startup if any of these is missing)
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini API key — powers gatekeeper, answer, extraction, summarization.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# Pinecone (vector store) API key.
PINECONE_API_KEY=your-key-here

# Neo4j knowledge-graph password (URI/username have working defaults below).
NEO4J_PASSWORD=your-password-here

# ─────────────────────────────────────────────────────────────────────────────
# Vector store (Pinecone)
# ─────────────────────────────────────────────────────────────────────────────
# Main clinical-knowledge index (the chunked reference corpus).
PINECONE_INDEX_NAME=enervara-specialists
# NOTE: vector retrieval is restricted to a NAMESPACE, set in code, not here:
#   graphrag/domain/vocabulary.py :: PINECONE_NAMESPACE = "pulmonology_v1"
# Your data MUST be ingested into that namespace:
#   python ingest_pinecone.py --namespace pulmonology_v1

# ─────────────────────────────────────────────────────────────────────────────
# Knowledge graph (Neo4j)
# Local desktop:  NEO4J_URI=bolt://127.0.0.1:7687
# Neo4j Aura:     NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
#   ⚠️ On Aura the USERNAME is always `neo4j` (NOT the instance id), and the
#      database is always `neo4j`. Use the password from Aura's downloaded
#      credentials file. The instance id only appears in the URI host.
# ─────────────────────────────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USERNAME=neo4j

# ─────────────────────────────────────────────────────────────────────────────
# Models (all default to gemini-2.5-flash-lite; override per role if needed)
# ─────────────────────────────────────────────────────────────────────────────
ANSWER_MODEL=gemini-2.5-flash-lite
QUERY_ANALYZER_MODEL=gemini-2.5-flash-lite
EXTRACTION_MODEL=gemini-2.5-flash-lite
SUMMARIZATION_MODEL=gemini-2.5-flash-lite
CLASSIFIER_MODEL=gemini-2.5-flash-lite
CLEANING_MODEL=gemini-2.5-flash-lite

# ─────────────────────────────────────────────────────────────────────────────
# Session memory (Redis) — OPTIONAL. Falls back to in-process RAM if absent,
# which means sessions are lost on restart and not shared across workers.
# Use a real Redis in production.
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SEC=7200

# ─────────────────────────────────────────────────────────────────────────────
# Episodic (long-term per-user) memory — Pinecone-backed. Engages only when a
# --user-id is supplied AND the index exists. Set ENABLED=false to disable.
# ─────────────────────────────────────────────────────────────────────────────
EPISODIC_MEMORY_ENABLED=true
PINECONE_EPISODIC_INDEX_NAME=episodicmemory
# The episodic index can live in a SEPARATE Pinecone account/project — give its
# own API key here. If unset, the main PINECONE_API_KEY is used.
# (Spelling kept as EPSIODIC_API_KEY to match the existing deployment.)
EPSIODIC_API_KEY=your-episodic-pinecone-key
EPISODIC_DEFAULT_TOP_K=20
EPISODIC_DEFAULT_RETURN_K=5
EPISODIC_DECAY_HALF_LIFE_DAYS=14
EPISODIC_MAX_CLARIFICATIONS_PER_TURN=1

# ─────────────────────────────────────────────────────────────────────────────
# HTTP service knobs (used only once an API wrapper exists — see ROADMAP P1)
# ─────────────────────────────────────────────────────────────────────────────
# PORT=8000
# LOG_LEVEL=INFO
# API_KEY=set-to-require-x-api-key-on-requests
# CORS_ORIGINS=*
